# Supabase — opcional.
# Si rellenas estas dos variables, la app usa Supabase (auth + base de datos en la nube).
# Si las dejas vacías, la app funciona 100% en local con localStorage (sin login real).
#
# Cópialo a un archivo llamado `.env` y rellena tus valores:
#   cp .env.example .env

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
